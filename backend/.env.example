# GROQ API Key for AI chat functionality
GROQ_API_KEY=your_groq_api_key_here

# MongoDB Connection URL
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URL=mongodb://localhost:27017/visa_db

# ==================== Scheduler Configuration ====================

# Enable or disable the scheduler (true/false)
# When disabled, no scheduled jobs will run
SCHEDULER_ENABLED=true

# Timezone for scheduler (use IANA timezone names)
# Examples: UTC, America/New_York, Europe/London, Asia/Kolkata
SCHEDULER_TIMEZONE=UTC

# Daily update time (24-hour format)
# Hour and minute when daily embassy data update runs
SCHEDULER_DAILY_HOUR=2
SCHEDULER_DAILY_MINUTE=0

# Weekly deep scan time
# Day of week: 0=Monday, 6=Sunday
# Hour: 24-hour format
SCHEDULER_WEEKLY_DAY=6
SCHEDULER_WEEKLY_HOUR=3

# Maximum consecutive failures before alerting
# After this many consecutive failures, an alert will be triggered
SCHEDULER_MAX_FAILURES=3

# ==================== Database Configuration ====================

# Database name for MongoDB
DATABASE_NAME=visa_db

# ==================== Production Settings (Optional) ====================

# Redis URL for production job persistence (optional)
# If not set, scheduler uses in-memory storage
# REDIS_URL=redis://localhost:6379/0