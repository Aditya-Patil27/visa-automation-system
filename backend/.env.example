# GROQ API Key for AI chat functionality
GROQ_API_KEY=your_groq_api_key_here

# MongoDB Connection URL
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URL=mongodb://localhost:27017/visa_db

# ==================== Scheduler Configuration ====================

# Enable or disable the scheduler (true/false)
# When disabled, no scheduled jobs will run
SCHEDULER_ENABLED=true

# Timezone for scheduler (use IANA timezone names)
# Examples: UTC, America/New_York, Europe/London, Asia/Kolkata
SCHEDULER_TIMEZONE=UTC

# Daily update time (24-hour format)
# Hour and minute when daily embassy data update runs
SCHEDULER_DAILY_HOUR=2
SCHEDULER_DAILY_MINUTE=0

# Weekly deep scan time
# Day of week: 0=Monday, 6=Sunday
# Hour: 24-hour format
SCHEDULER_WEEKLY_DAY=6
SCHEDULER_WEEKLY_HOUR=3

# Maximum consecutive failures before alerting
# After this many consecutive failures, an alert will be triggered
SCHEDULER_MAX_FAILURES=3

# ==================== Database Configuration ====================

# Database name for MongoDB
DATABASE_NAME=visa_db

# ==================== Production Settings (Optional) ====================

# Redis URL for caching (required for performance optimization)
# Format: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Uvicorn worker count for production (supports 100+ concurrent users)
# Recommended: 2-4 workers based on CPU cores
WORKER_COUNT=4

# Cache TTL settings (in seconds)
CACHE_TTL_DEFAULT=300
CACHE_TTL_RAG=3600
CACHE_TTL_VISA=600
CACHE_TTL_SESSION=1800

# ==================== Email Configuration (SMTP) ====================

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Alternative: SendGrid API (recommended for production)
SENDGRID_API_KEY=

# Email sender settings
EMAIL_FROM=noreply@visa-automation.com
EMAIL_FROM_NAME=Visa Automation System

# ==================== SMS Configuration (Twilio) ====================

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ==================== Notification Toggles ====================

# Enable/disable notification channels
EMAIL_ENABLED=true
SMS_ENABLED=false