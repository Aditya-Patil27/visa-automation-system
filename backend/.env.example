# ==================== Required Settings ====================

# JWT Secret Key (REQUIRED — minimum 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change_me_to_a_random_secret_at_least_32_characters_long

# CORS origin for frontend (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# JWT token expiry in minutes (default: 30)
JWT_EXPIRE_MINUTES=30

# GROQ API Key for AI chat functionality
GROQ_API_KEY=

# MongoDB Connection URL
MONGODB_URL=mongodb://localhost:27017/visa_db

# Google Vision API Key (for OCR)
GOOGLE_VISION_API_KEY=

# ==================== Scheduler Configuration ====================

# Enable or disable the scheduler (true/false)
SCHEDULER_ENABLED=false

# Timezone for scheduler (use IANA timezone names)
SCHEDULER_TIMEZONE=UTC

# Daily update time (24-hour format)
SCHEDULER_DAILY_HOUR=2
SCHEDULER_DAILY_MINUTE=0

# Weekly deep scan time (0=Monday, 6=Sunday)
SCHEDULER_WEEKLY_DAY=6
SCHEDULER_WEEKLY_HOUR=3

# Maximum consecutive failures before alerting
SCHEDULER_MAX_FAILURES=3

# ==================== Database Configuration ====================

DATABASE_NAME=visa_db

# ==================== Performance Settings ====================

# Redis URL for caching (optional, system works without it)
REDIS_URL=redis://localhost:6379/0

# Uvicorn worker count for production
WORKER_COUNT=4

# Cache TTL settings (in seconds)
CACHE_TTL_DEFAULT=300
CACHE_TTL_RAG=3600
CACHE_TTL_VISA=600
CACHE_TTL_SESSION=1800

# ==================== Email Configuration (SMTP) ====================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SENDGRID_API_KEY=
EMAIL_FROM=noreply@visa-automation.com
EMAIL_FROM_NAME=Visa Automation System

# ==================== SMS Configuration (Twilio) ====================

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ==================== Notification Toggles ====================

EMAIL_ENABLED=true
SMS_ENABLED=false
